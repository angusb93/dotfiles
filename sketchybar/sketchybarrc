#!/bin/bash

source "$HOME/.config/sketchybar/colors.sh"
PLUGIN_DIR="$HOME/.config/sketchybar/plugins"

# Bar appearance
sketchybar --bar \
  position=top \
  height=32 \
  color=$BAR_BG \
  shadow=off \
  padding_left=8 \
  padding_right=8

# Default item settings
sketchybar --default \
  label.font="FiraMono Nerd Font:Medium:14.0" \
  label.color=$BAR_FG \
  label.padding_left=10 \
  label.padding_right=10 \
  background.height=26 \
  background.corner_radius=5 \
  padding_left=6 \
  padding_right=6

# Register aerospace workspace change event
sketchybar --add event aerospace_workspace_change

# Workspace items — all hidden until aerospace.sh sets state
WORKSPACES=(1 A B C D E F G I M N O P Q R S T U V W X Y Z)
for ws in "${WORKSPACES[@]}"; do
  sketchybar --add item space.$ws center \
    --set space.$ws \
      label="$ws" \
      background.color=$ACCENT \
      background.drawing=off \
      label.color=$MUTED \
      drawing=off \
      click_script="aerospace workspace $ws"
done

# Hidden listener — updates all space items on workspace change
sketchybar --add item aerospace_listener left \
  --set aerospace_listener \
    drawing=off \
    script="$PLUGIN_DIR/aerospace.sh" \
  --subscribe aerospace_listener aerospace_workspace_change

# Right side: meeting
sketchybar --add item meeting right \
  --set meeting \
    drawing=off \
    update_freq=30 \
    script="$PLUGIN_DIR/meeting.sh" \
  --subscribe meeting system_woke

# Right side: battery
sketchybar --add item battery right \
  --set battery \
    update_freq=60 \
    script="$PLUGIN_DIR/battery.sh" \
  --subscribe battery system_woke power_source_change

# Right side: volume
sketchybar --add item volume right \
  --set volume \
    update_freq=30 \
    script="$PLUGIN_DIR/volume.sh" \
  --subscribe volume volume_change

# Right side: clock
sketchybar --add item clock right \
  --set clock \
    update_freq=10 \
    script="$PLUGIN_DIR/clock.sh"

sketchybar --update

# Initial workspace state
"$PLUGIN_DIR/aerospace.sh"
